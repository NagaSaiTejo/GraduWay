# Copy this to .env — never commit real .env

MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster.mongodb.net/GraduWay
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster.mongodb.net/GraduWay
PORT=5000
JWT_SECRET=your_jwt_secret_minimum_32_chars
ADMIN_REGISTRATION_CODE=your_secure_admin_code
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase (injected at Flutter build time via --dart-define)
# flutter run --dart-define=FIREBASE_WEB_API_KEY=AIza...
FIREBASE_WEB_API_KEY=your_firebase_web_api_key
FIREBASE_ANDROID_API_KEY=your_firebase_android_api_key
FIREBASE_IOS_API_KEY=your_firebase_ios_api_key