#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# ─── Security / Environment Variables ───────────────────────────────────────
# NEVER commit real .env files (they contain DB passwords, secret keys)
.env
.env.local
.env.production
.env.*
**/.env
**/.env.local
**/.env.production
**/.env.*
backend/node_modules/

# Node modules — reinstall with `npm install`
backend/node_modules/

# Uploaded user files — these are generated at runtime, not source code
backend/uploads/

# npm debug logs
backend/npm-debug.log*
backend/yarn-debug.log*
backend/yarn-error.log*

# Lock file is OK to commit (pinned versions), but node_modules is not
# backend/package-lock.json  ← keep this tracked
